# AgentHub — environment file
#
# The installer (scripts/install.sh) generates a filled-in .env based on
# the TUI answers or AGENTHUB_* env vars (headless mode). This file
# documents every variable for manual setups and review.
#
# Variables marked "installer-managed" should not be hand-edited; use
# `agenthub reconfigure-access` or re-run the installer when they need
# to change.


# ====================================================================
# Access mode + public URL
# ====================================================================

# Domain (or LAN IP) where AgentHub is reachable from operator devices.
# Examples: localhost, 10.0.0.10, agenthub.example.com
DOMAIN=localhost

# Access mode. Determines how Traefik exposes the install.
#   lan     (default — HTTP on :80, no TLS, accessible from your local
#            network. Right choice for ~99% of installs.)
#   public  (Let's Encrypt HTTPS. Sub-mode set by AGENTHUB_TLS_MODE.)
#
# See docs/install/access-modes.md for the full guide.
AGENTHUB_ACCESS_MODE=lan

# Public-mode sub-mode (only used when AGENTHUB_ACCESS_MODE=public).
#   public-alpn  (Let's Encrypt via TLS-ALPN-01 — port :443 must be
#                 reachable from the public internet)
#   dns-01       (Let's Encrypt via DNS-01 — for internal-only hosts;
#                 requires AGENTHUB_TLS_DNS_PROVIDER + lego env vars)
# AGENTHUB_TLS_MODE=public-alpn

# Let's Encrypt contact email. Required when AGENTHUB_ACCESS_MODE=public.
TLS_EMAIL=you@example.com

# DNS-01 provider name (lego provider id: cloudflare, route53,
# digitalocean, hetzner, gandi, linode, ~80 others). Required when
# AGENTHUB_TLS_MODE=dns-01. Full list:
#   https://go-acme.github.io/lego/dns/
# AGENTHUB_TLS_DNS_PROVIDER=

# Cloudflare API token (when AGENTHUB_TLS_DNS_PROVIDER=cloudflare). For
# other DNS providers, set the lego-native env vars in your shell before
# running the installer — they're forwarded verbatim into the Traefik
# container.
# AGENTHUB_CLOUDFLARE_API_TOKEN=

# Compose file chain. Generated by the installer based on access mode.
# Installer-managed — do not hand-edit. Use `agenthub reconfigure-access`.
# COMPOSE_FILE=docker-compose.yml:traefik.override.yml

# Public URL stamped into the operator-facing UI + cookies.
# Installer-managed.
AGENTHUB_PUBLIC_URL=http://localhost

# Traefik entrypoint name for the agenthub-server router. Installer-managed.
#   web        (lan mode)
#   websecure  (public mode)
AGENTHUB_TRAEFIK_ENTRYPOINT=web

# Traefik router rule. Installer-managed based on DOMAIN.
AGENTHUB_HOST_RULE=PathPrefix(`/`)

# Hostname / IP for operator-facing share URLs (local-docker deploy
# target announces deploys at http://<PUBLIC_HOST>:<port>). Defaults
# to DOMAIN. Override when DOMAIN=localhost but you want the LAN IP
# (e.g. AGENTHUB_PUBLIC_HOST=10.0.0.10), or when local-docker deploys
# are served from a different hostname than the AgentHub UI.
AGENTHUB_PUBLIC_HOST=

# Absolute host path of the git checkout, mounted into agenthub-server
# at /repo (rw). Lets the server read version info + spawn the updater
# container. Installer-managed.
AGENTHUB_REPO_DIR=/path/to/agenthubv2

# uid:gid that owns AGENTHUB_REPO_DIR on the host. scripts/agenthub
# chowns back to this value after every root operation so .git/objects
# doesn't end up root-owned. Installer captures from SUDO_UID/SUDO_GID.
AGENTHUB_OWNER=1000:1000


# ====================================================================
# Provisioner (where session containers run)
# ====================================================================

# One of:
#   docker          (sessions on this host's Docker daemon — default)
#   dokploy-remote  (sessions provisioned via an existing Dokploy instance)
PROVISIONER_MODE=docker

# Docker driver only. If empty, dockerode auto-discovers (usually means
# /var/run/docker.sock). For rootless Docker, point at the daemon's TCP
# socket (see docs/operations/rootless-docker.md if available).
# Example: tcp://rootless-docker.agenthub:2375
DOCKER_HOST=

# Dokploy-remote driver only. Connect to an existing Dokploy instance.
DOKPLOY_URL=
DOKPLOY_API_TOKEN=
DOKPLOY_PROJECT_ID=
DOKPLOY_ENVIRONMENT_ID=


# ====================================================================
# Images (server + workspace container)
# ====================================================================

# Default points at the GHCR releases. For local-build installs, the
# installer rewrites these to "agenthubv2-server:local" /
# "agenthubv2-workspace:local".
AGENTHUB_SERVER_IMAGE=ghcr.io/physikal/agenthubv2-server:latest
WORKSPACE_IMAGE=ghcr.io/physikal/agenthubv2-workspace:latest


# ====================================================================
# Infisical (bundled secret store)
# ====================================================================

# Bootstrap secrets. Installer generates random values; rotating these
# means re-bootstrapping the Infisical project.
INFISICAL_DB_PASSWORD=replace-me-random
INFISICAL_REDIS_PASSWORD=replace-me-random
INFISICAL_ENCRYPTION_KEY=replace-me-32-bytes-hex
INFISICAL_AUTH_SECRET=replace-me-random

# Machine-identity credentials AgentHub uses to call Infisical. The
# installer creates the project + identity on first run and writes
# these back. Filled in automatically — do not hand-edit.
INFISICAL_PROJECT_ID=
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
INFISICAL_ENVIRONMENT=prod

# Infisical console admin login. Persisted so operators can recover it
# via Settings → Secrets → "Reveal Infisical login" (admin-only, gated
# by the AgentHub password). Required because Infisical disables
# self-registration and has no SMTP reset flow out of the box.
INFISICAL_ADMIN_EMAIL=
INFISICAL_ADMIN_PASSWORD=


# ====================================================================
# Admin bootstrap (optional)
# ====================================================================

# If set, the server seeds this as the admin password instead of
# generating a random one. Used by non-interactive installs.
AGENTHUB_ADMIN_PASSWORD=


# ====================================================================
# Tuning (optional)
# ====================================================================

# Maximum concurrent active sessions per non-admin user. Admins have no
# limit. Default: 3.
# AGENTHUB_MAX_ACTIVE_SESSIONS=3

# Host-side port mapping for the Traefik front door. Container-side
# ports are always Traefik's standard 80/443/8443 — these only change
# what ports get exposed on the host. Useful when co-locating AgentHub
# with another web service. The installer's interactive flow doesn't
# ask about these; set them here and re-run `agenthub restart` to apply.
# AGENTHUB_HTTP_PORT=80
# AGENTHUB_HTTPS_PORT=443       # only used when AGENTHUB_ACCESS_MODE=public
# AGENTHUB_INFISICAL_PORT=8443
