# AgentHub v2 — environment file
#
# The installer (npx agenthub-install) generates a filled-in .env based on
# TUI answers. This file documents every variable for manual setups and
# agent-driven headless installs.

# ---------- Required: public URL + TLS ----------
# Domain where AgentHub is reachable. For local-only, "localhost" works
# with a self-signed cert (Traefik falls back to default cert when
# certresolver can't complete the ACME dance).
DOMAIN=localhost

# Email Let's Encrypt uses for expiry notifications.
TLS_EMAIL=you@example.com

# Traefik router rule. Installer sets this based on DOMAIN:
#   DOMAIN=localhost  → AGENTHUB_HOST_RULE=PathPrefix(`/`)   (accepts any Host,
#                       including LAN IP access — needed because browsers send
#                       Host: <ip> when you hit the box directly)
#   DOMAIN=real.tld   → AGENTHUB_HOST_RULE=Host(`real.tld`)  (strict — refuses
#                       requests with a different Host header, a production
#                       best-practice against Host-header confusion attacks)
AGENTHUB_HOST_RULE=PathPrefix(`/`)

# Hostname / IP users type in their browser to reach this box. Stamped into
# the URL of every local-docker deploy (http://<PUBLIC_HOST>:<auto-port>).
# Defaults to DOMAIN — override when DOMAIN=localhost and you want the LAN
# IP instead (e.g. AGENTHUB_PUBLIC_HOST=192.168.1.10), or when deployments
# are served from a different hostname than the AgentHub UI.
AGENTHUB_PUBLIC_HOST=

# Absolute host path of the git checkout, mounted into agenthub-server at
# /repo (rw). Lets the server read version info for the web-UI update
# button and hand off to the bundled agenthubv2-updater image. The
# installer fills this in via process.cwd() at install time.
AGENTHUB_REPO_DIR=/path/to/agenthubv2

# uid:gid that owns the AGENTHUB_REPO_DIR checkout on the host. The updater
# container runs git + docker as root; without this, fresh objects under
# .git/objects/ stay root-owned and later non-sudo `git` calls fail with
# "insufficient permission for adding an object to repository database".
# scripts/agenthub's EXIT trap chowns back to this value after every root
# run. install.sh captures it from SUDO_UID/SUDO_GID (or the current user).
AGENTHUB_OWNER=1000:1000

# ---------- Provisioner ----------
# One of: docker | dokploy-local | dokploy-remote
PROVISIONER_MODE=docker

# Docker driver only. If empty, dockerode uses its default discovery.
# RECOMMENDED: point at a rootless Docker daemon over TCP:
#   DOCKER_HOST=tcp://rootless-docker.agenthub:2375
DOCKER_HOST=

# Dokploy driver only (local overlay OR remote).
DOKPLOY_URL=
DOKPLOY_API_TOKEN=
DOKPLOY_PROJECT_ID=
DOKPLOY_ENVIRONMENT_ID=
# Set by docker-compose.dokploy.yml overlay when PROVISIONER_MODE=dokploy-local.
DOKPLOY_DB_PASSWORD=

# ---------- Images ----------
AGENTHUB_SERVER_IMAGE=ghcr.io/physikal/agenthubv2-server:latest
WORKSPACE_IMAGE=ghcr.io/physikal/agenthubv2-workspace:latest

# ---------- Infisical ----------
# Postgres + Redis passwords (any random string; installer generates these).
INFISICAL_DB_PASSWORD=replace-me-random
INFISICAL_REDIS_PASSWORD=replace-me-random
# 32-byte hex encryption key + AUTH_SECRET (installer generates).
INFISICAL_ENCRYPTION_KEY=replace-me-32-bytes-hex
INFISICAL_AUTH_SECRET=replace-me-random
# Machine-identity credentials for AgentHub to call Infisical. The installer
# creates the project + identity on first-run and writes these back.
INFISICAL_PROJECT_ID=
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
INFISICAL_ENVIRONMENT=prod
# Infisical console login (admin user created during bootstrap). Persisted so
# operators can recover it via the Secrets page "Reveal Infisical login"
# flow — admin-only, gated by the AgentHub admin password. Infisical ships
# with self-registration disabled and no working SMTP reset, so losing these
# would lock the admin console out permanently.
INFISICAL_ADMIN_EMAIL=
INFISICAL_ADMIN_PASSWORD=

# ---------- Admin bootstrap (optional) ----------
# If set, the server seeds this as the admin password instead of generating
# a random one. Used by non-interactive installs.
AGENTHUB_ADMIN_PASSWORD=
