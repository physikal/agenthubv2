#!/usr/bin/env bash
#
# agenthub — manage an AgentHub install from the command line.
#
#   agenthub update            Pull latest, rebuild images, recreate stack.
#   agenthub update --check    Show what would happen (no changes).
#   agenthub status            Git SHA, latest origin SHA, compose services.
#   agenthub logs [service]    Tail compose logs (defaults to agenthub-server).
#   agenthub restart [service] Restart a service (defaults to all).
#   agenthub version           Current git SHA + commit date.
#
# Installed to /usr/local/bin/agenthub by scripts/install.sh. Reads the
# install directory from /etc/agenthub/config. Re-run scripts/install.sh
# if that file is missing or stale.

set -euo pipefail

c_reset=$'\033[0m'; c_bold=$'\033[1m'
c_cyan=$'\033[1;36m'; c_yel=$'\033[1;33m'; c_red=$'\033[1;31m'; c_grn=$'\033[1;32m'
msg()  { printf '%s[agenthub]%s %s\n' "$c_cyan" "$c_reset" "$*"; }
ok()   { printf '%s[ok]%s %s\n'        "$c_grn"  "$c_reset" "$*"; }
warn() { printf '%s[warn]%s %s\n'      "$c_yel"  "$c_reset" "$*" >&2; }
die()  { printf '%s[error]%s %s\n'     "$c_red"  "$c_reset" "$*" >&2; exit 1; }

# Load AGENTHUB_DIR + AGENTHUB_OWNER from env → /etc/agenthub/config.
# Env wins (the updater container passes values via -e without mounting
# /etc/agenthub). Config is the source of truth on the host shell.
CONFIG_FILE="${AGENTHUB_CONFIG:-/etc/agenthub/config}"
if [[ -r "$CONFIG_FILE" ]]; then
  _env_DIR="${AGENTHUB_DIR:-}"
  _env_OWNER="${AGENTHUB_OWNER:-}"
  # shellcheck disable=SC1090
  . "$CONFIG_FILE"
  [[ -n "$_env_DIR"   ]] && AGENTHUB_DIR="$_env_DIR"
  [[ -n "$_env_OWNER" ]] && AGENTHUB_OWNER="$_env_OWNER"
  unset _env_DIR _env_OWNER
fi
if [[ -z "${AGENTHUB_DIR:-}" ]]; then
  die "AGENTHUB_DIR not set and $CONFIG_FILE not found. Reinstall, or export AGENTHUB_DIR=/path/to/agenthubv2."
fi
: "${AGENTHUB_DIR:?AGENTHUB_DIR not set}"
[[ -d "$AGENTHUB_DIR/.git" ]] || die "$AGENTHUB_DIR is not a git repo — did the install change location?"
[[ -f "$AGENTHUB_DIR/compose/docker-compose.yml" ]] || die "compose file missing at $AGENTHUB_DIR"

COMPOSE_FILE="$AGENTHUB_DIR/compose/docker-compose.yml"
ENV_FILE="$AGENTHUB_DIR/compose/.env"

# sudo unless already root
SUDO=""; [[ "$(id -u)" -ne 0 ]] && SUDO="sudo"

compose() {
  $SUDO docker compose -f "$COMPOSE_FILE" --env-file "$ENV_FILE" "$@"
}

cmd_version() {
  cd "$AGENTHUB_DIR"
  local sha date
  sha="$(git rev-parse --short HEAD)"
  date="$(git log -1 --format=%cI HEAD)"
  printf 'AgentHub at %s\n  commit : %s\n  date   : %s\n' "$AGENTHUB_DIR" "$sha" "$date"
}

# Ensure `origin/main` is actually a tracked remote ref before we try to
# resolve it. `git clone --depth=1 --branch <X>` (what quick-install.sh
# uses when AGENTHUB_BRANCH is set) installs a narrow refspec that only
# tracks branch X — so for installs started from a non-main branch,
# `origin/main` doesn't exist and `git rev-parse origin/main` throws.
# Widening is idempotent; fetch is best-effort.
ensure_origin_main_tracked() {
  cd "$AGENTHUB_DIR"
  git remote set-branches --add origin main 2>/dev/null || true
  git fetch --quiet origin main 2>/dev/null || true
}

cmd_status() {
  cd "$AGENTHUB_DIR"
  ensure_origin_main_tracked
  local local_sha remote_sha ahead behind
  local_sha="$(git rev-parse HEAD)"
  remote_sha="$(git rev-parse origin/main)"
  ahead="$(git rev-list --count "$remote_sha..$local_sha")"
  behind="$(git rev-list --count "$local_sha..$remote_sha")"

  printf '%sGit%s\n' "$c_bold" "$c_reset"
  printf '  installed: %s\n' "$(git rev-parse --short HEAD)"
  printf '  origin   : %s\n' "$(git rev-parse --short origin/main)"
  if [[ "$behind" -gt 0 ]]; then
    printf '  %s%s commit(s) behind origin/main%s — run `agenthub update` to pull\n' "$c_yel" "$behind" "$c_reset"
  elif [[ "$ahead" -gt 0 ]]; then
    printf '  %s%s commit(s) ahead of origin/main%s (local-only work)\n' "$c_yel" "$ahead" "$c_reset"
  else
    printf '  %sup to date%s\n' "$c_grn" "$c_reset"
  fi
  printf '\n%sCompose services%s\n' "$c_bold" "$c_reset"
  compose ps --format "table {{.Service}}\t{{.State}}\t{{.Status}}"
}

# True if the local image has drifted from the repo: either a commit has
# landed since the image was built that touched one of the given paths,
# or the image is missing on an install that expects a :local build.
# Reads the `org.agenthub.git-sha` label (baked in at `docker build`
# time from `git rev-parse HEAD`) and diffs against current HEAD. This
# replaces an earlier mtime/committer-time heuristic that was fragile
# across timezones and `git reset` (the file-mtime reset after a pull
# produced false-negatives like the one that stranded VM 915 on a
# ghost container image in April 2026). When compose/.env pins a
# registry image (AGENTHUB_SERVER_IMAGE=ghcr.io/...), missing :local
# tags are expected and the function returns false.
image_drift_for_paths() {
  local image="$1"; shift
  local image_sha
  image_sha="$($SUDO docker image inspect \
    --format '{{index .Config.Labels "org.agenthub.git-sha"}}' \
    "$image" 2>/dev/null || true)"
  if [[ -z "$image_sha" ]]; then
    # Image missing entirely. Only "stale" on a :local-flavored install;
    # on registry installs the :local tag is expected to be absent.
    grep -qE '=agenthubv2-[a-z-]+:local' "$ENV_FILE" 2>/dev/null
    return
  fi
  if [[ "$image_sha" == "unknown" || "$image_sha" == "<no value>" ]]; then
    # Pre-hardening image built before the GIT_SHA label existed.
    # Rebuild once to start tracking labels.
    return 0
  fi
  # History could have been rewritten (force-push, different fork) such
  # that the recorded SHA is no longer reachable. Be safe and rebuild.
  if ! (cd "$AGENTHUB_DIR" && git cat-file -e "$image_sha^{commit}" 2>/dev/null); then
    return 0
  fi
  local changed
  changed="$( (cd "$AGENTHUB_DIR" && git diff --name-only "$image_sha" HEAD -- "$@" 2>/dev/null) || true)"
  [[ -n "$changed" ]]
}

# Rebuild every image whose build context has moved — either via a new
# commit range ($from..$to) or because the image itself is older than the
# latest commit touching its Dockerfile/context. The staleness trigger
# catches the "pre-#18 CLI re-exec'd after git reset, post-#18 CLI saw
# HEAD and bailed before rebuilding" migration path and any comparable
# image-vs-repo drift. Returns the count of images rebuilt.
rebuild_changed_images() {
  local from="$1" to="$2"
  cd "$AGENTHUB_DIR"
  local changed=""
  if [[ -n "$from" && -n "$to" && "$from" != "$to" ]]; then
    changed="$(git diff --name-only "$from" "$to" -- docker/ packages/ scripts/ || true)"
  fi
  local rebuild_server=0 rebuild_workspace=0 rebuild_updater=0
  # packages/docs/ is in server_paths because Dockerfile.server bakes the
  # Starlight build into dist/public/docs/ at image build time — a docs-only
  # commit needs a server rebuild or the new pages never reach users.
  local server_paths=(docker/Dockerfile.server packages/server packages/web packages/agent packages/docs pnpm-lock.yaml package.json)
  local workspace_paths=(docker/Dockerfile.agent-workspace docker/agent-workspace-entrypoint.sh packages/agent)
  local updater_paths=(docker/Dockerfile.updater)
  if [[ -n "$changed" ]]; then
    if echo "$changed" | grep -qE '^(docker/Dockerfile\.server|packages/server/|packages/web/|packages/agent/|packages/docs/|pnpm-lock\.yaml|package\.json)'; then
      rebuild_server=1
    fi
    if echo "$changed" | grep -qE '^(docker/Dockerfile\.agent-workspace|docker/agent-workspace-entrypoint\.sh|packages/agent/)'; then
      rebuild_workspace=1
    fi
    # The updater image no longer bakes scripts/agenthub (it bind-mounts
    # /repo at run time), so CLI-only changes don't require an updater
    # rebuild. Only rebuild when the Dockerfile itself moves.
    if echo "$changed" | grep -qE '^docker/Dockerfile\.updater$'; then
      rebuild_updater=1
    fi
  fi
  [[ $rebuild_server    -eq 0 ]] && image_drift_for_paths agenthubv2-server:local    "${server_paths[@]}"    && rebuild_server=1
  [[ $rebuild_workspace -eq 0 ]] && image_drift_for_paths agenthubv2-workspace:local "${workspace_paths[@]}" && rebuild_workspace=1
  [[ $rebuild_updater   -eq 0 ]] && image_drift_for_paths agenthubv2-updater:local   "${updater_paths[@]}"   && rebuild_updater=1

  if [[ "$rebuild_server" -eq 0 && "$rebuild_workspace" -eq 0 && "$rebuild_updater" -eq 0 ]]; then
    msg "no image-relevant changes — skipping rebuild"
    return
  fi
  # Baked into the image via ARG GIT_SHA / LABEL org.agenthub.git-sha.
  # image_drift_for_paths reads the label on next update to decide rebuild.
  local git_sha
  git_sha="$( (cd "$AGENTHUB_DIR" && git rev-parse HEAD) 2>/dev/null || echo unknown )"
  if [[ "$rebuild_server" -eq 1 ]]; then
    msg "rebuilding agenthubv2-server:local"
    $SUDO docker build --build-arg "GIT_SHA=$git_sha" -f "$AGENTHUB_DIR/docker/Dockerfile.server" -t agenthubv2-server:local "$AGENTHUB_DIR"
  fi
  if [[ "$rebuild_workspace" -eq 1 ]]; then
    msg "rebuilding agenthubv2-workspace:local"
    $SUDO docker build --build-arg "GIT_SHA=$git_sha" -f "$AGENTHUB_DIR/docker/Dockerfile.agent-workspace" -t agenthubv2-workspace:local "$AGENTHUB_DIR"
  fi
  if [[ "$rebuild_updater" -eq 1 ]]; then
    msg "rebuilding agenthubv2-updater:local"
    $SUDO docker build --build-arg "GIT_SHA=$git_sha" -f "$AGENTHUB_DIR/docker/Dockerfile.updater" -t agenthubv2-updater:local "$AGENTHUB_DIR"
  fi
}

# After `compose up -d --force-recreate`, confirm the running server
# container is actually on the newly-built :local image. Catches the
# silent-failure class where compose returns 0 without recreating (e.g.
# container left on a now-dangling image from a prior build) — the
# exact bug that left VM 915 serving a stale React bundle for days in
# April 2026.
#
# On registry-pinned installs there is no :local tag to compare; we
# accept "container exists" as verification and move on.
verify_server_image() {
  local container_id
  container_id="$(compose ps -q agenthub-server 2>/dev/null | head -1)"
  if [[ -z "$container_id" ]]; then
    die "agenthub-server container not found after recreate — check 'compose ps' output above"
  fi
  local container_image tag_image
  container_image="$($SUDO docker inspect "$container_id" \
    --format '{{.Image}}' 2>/dev/null || true)"
  tag_image="$($SUDO docker image inspect agenthubv2-server:local \
    --format '{{.Id}}' 2>/dev/null || true)"
  if [[ -z "$container_image" ]]; then
    die "couldn't read server container image ID — recreate may have failed"
  fi
  if [[ -z "$tag_image" ]]; then
    ok "server container running (registry-pinned install — no :local verify)"
    return 0
  fi
  if [[ "$container_image" != "$tag_image" ]]; then
    die "server container is on image ${container_image:7:12} but :local tag points at ${tag_image:7:12} — force-recreate didn't take. Investigate: docker compose -f $COMPOSE_FILE up -d --force-recreate agenthub-server"
  fi
  ok "server container image matches :local tag"
}

# Poll the front door until it reports the expected SHA, confirming the
# new image is actually handling traffic end-to-end. Images that predate
# the AGENTHUB_GIT_SHA env var report "unknown", in which case we fall
# back to a plain 200-OK check (one-time upgrade path).
probe_front_door() {
  local domain expected
  domain="$(grep -E '^DOMAIN=' "$ENV_FILE" | cut -d= -f2-)"
  [[ -z "$domain" ]] && return 0
  expected="$( (cd "$AGENTHUB_DIR" && git rev-parse HEAD) 2>/dev/null || echo "")"
  local deadline=$((SECONDS + 60))
  local body served=""
  while [[ "$SECONDS" -lt "$deadline" ]]; do
    body="$(curl -ksf -m 5 --resolve "${domain}:443:127.0.0.1" \
      "https://${domain}/api/health" 2>/dev/null || true)"
    if [[ -n "$body" ]]; then
      served="$(echo "$body" | grep -oE '"sha":"[^"]+"' | head -1 | cut -d'"' -f4)"
      # Legacy image: no SHA field or literal "unknown". 200 is the best signal.
      if [[ -z "$served" || "$served" == "unknown" || -z "$expected" ]]; then
        ok "front-door probe green: https://${domain}/api/health"
        return 0
      fi
      if [[ "$served" == "$expected" ]]; then
        ok "front-door serving expected SHA: ${expected:0:7}"
        return 0
      fi
    fi
    sleep 2
  done
  warn "front-door did not converge to ${expected:0:7} within 60s (last served: ${served:-<no response>}). Inspect: docker logs agenthub-agenthub-server-1"
  return 1
}

# Bring compose/.env forward across schema changes. Any ${VAR} the compose
# file references that isn't in .env would break `docker compose` at the
# parse step — so we audit + backfill with sensible defaults before invoking
# compose. Idempotent.
migrate_env() {
  # AGENTHUB_REPO_DIR was added in the web-UI-update commit — installs from
  # earlier CLI versions won't have it. Default to AGENTHUB_DIR (the host
  # path we already know).
  if grep -q 'AGENTHUB_REPO_DIR' "$COMPOSE_FILE" && ! grep -q '^AGENTHUB_REPO_DIR=' "$ENV_FILE"; then
    msg "migrating: adding AGENTHUB_REPO_DIR=$AGENTHUB_DIR to compose/.env"
    echo "AGENTHUB_REPO_DIR=$AGENTHUB_DIR" >> "$ENV_FILE"
  fi
}

# Install the freshly-pulled CLI script over the one on PATH. Called at
# the END of cmd_update so the whole update runs under one code path
# (the currently-executing CLI). No re-exec. No-op when identical.
#
# Contract: rebuild_changed_images, migrate_env, and compose invocations
# are deterministic functions of (repo contents, docker CLI) — the
# currently-running CLI can execute them correctly against the fresh
# repo regardless of its own age. migrate_env migrations MUST be
# idempotent + backward-compatible so an older CLI can run a newer
# migration.
install_new_cli() {
  local my_path
  my_path="$(realpath "$(command -v agenthub)" 2>/dev/null || echo "")"
  local repo_script="$AGENTHUB_DIR/scripts/agenthub"
  [[ -z "$my_path" || ! -f "$repo_script" ]] && return 0
  if cmp -s "$repo_script" "$my_path"; then return 0; fi
  msg "installing new CLI at $my_path"
  $SUDO install -m 0755 "$repo_script" "$my_path"
}

cmd_update() {
  local check_only=0
  [[ "${1:-}" == "--check" ]] && check_only=1

  cd "$AGENTHUB_DIR"

  # When the updater runs inside the agenthubv2-updater container, every
  # git + filesystem write happens as container-root (uid 0), which on the
  # host bind mount means root-owned files the operator's shell user can't
  # touch without sudo. Restore ownership on exit.
  #
  # Resolution order for target owner:
  #   1. $AGENTHUB_OWNER — recorded at install time in /etc/agenthub/config
  #      (or passed via -e to the updater container). Authoritative, survives
  #      historical drift where package.json itself is already root-owned.
  #   2. stat package.json — fallback for upgrades from older installs that
  #      predate the AGENTHUB_OWNER var. Ignored when drifted to 0:0 so we
  #      don't perpetuate an already-broken state.
  local repo_owner=""
  if [[ "$(id -u)" -eq 0 ]]; then
    repo_owner="${AGENTHUB_OWNER:-}"
    if [[ -z "$repo_owner" ]] && [[ -f "$AGENTHUB_DIR/package.json" ]]; then
      local stat_owner
      stat_owner="$(stat -c '%u:%g' "$AGENTHUB_DIR/package.json" 2>/dev/null || true)"
      [[ -n "$stat_owner" && "$stat_owner" != "0:0" ]] && repo_owner="$stat_owner"
    fi
    if [[ -n "$repo_owner" && "$repo_owner" != "0:0" ]]; then
      # Restore ownership on every exit path, including errors.
      # shellcheck disable=SC2064
      trap "chown -R '$repo_owner' '$AGENTHUB_DIR' 2>/dev/null || true" EXIT
    else
      warn "can't determine install owner — repo may drift to root ownership. Set AGENTHUB_OWNER=<uid>:<gid> in /etc/agenthub/config and re-run."
    fi
  fi

  ensure_origin_main_tracked
  local local_sha remote_sha
  local_sha="$(git rev-parse HEAD)"
  remote_sha="$(git rev-parse origin/main)"

  # Images drift from the repo in two cases: (a) a prior update failed
  # mid-flight, or (b) a pre-#18 CLI self-update re-exec'd into the new
  # single-pass CLI, which saw HEAD and bailed before rebuilding. Catch
  # both by checking the image's baked GIT_SHA label against HEAD —
  # "nothing to do" must mean both fresh, not just git-fresh.
  local images_stale=0
  if image_drift_for_paths agenthubv2-server:local \
       docker/Dockerfile.server packages/server packages/web packages/agent packages/docs \
       pnpm-lock.yaml package.json \
    || image_drift_for_paths agenthubv2-workspace:local \
       docker/Dockerfile.agent-workspace docker/agent-workspace-entrypoint.sh packages/agent \
    || image_drift_for_paths agenthubv2-updater:local \
       docker/Dockerfile.updater; then
    images_stale=1
  fi

  if [[ "$local_sha" == "$remote_sha" && "$images_stale" -eq 0 ]]; then
    ok "already at origin/main (${local_sha:0:7}) — nothing to do"
    return 0
  fi

  if [[ "$local_sha" != "$remote_sha" ]]; then
    msg "update available: $(git rev-parse --short HEAD) → $(git rev-parse --short origin/main)"
    git --no-pager log --oneline "$local_sha..$remote_sha" | head -10 | sed 's/^/  /'
  else
    msg "repo at HEAD but local images drifted — rebuilding to catch up"
  fi

  if [[ "$check_only" -eq 1 ]]; then
    msg "--check: not applying"
    return 0
  fi

  msg "pulling + rebuilding"
  local old_sha="$local_sha"
  git reset --hard origin/main --quiet

  # Single-pass update under the currently-running CLI. No self-update
  # re-exec: rebuild, migrate, and recreate are all backward-compatible
  # operations against the new repo. Installing the new CLI happens
  # at the very end so any subsequent `agenthub` invocation picks it up.
  migrate_env
  rebuild_changed_images "$old_sha" "$remote_sha"

  # Two steps:
  #   1. `compose up -d` with no filter picks up config drift on every
  #      service (new ports on traefik, env changes on infisical, etc.)
  #      without recreating services whose config didn't move.
  #   2. `--force-recreate agenthub-server` guarantees the new image we
  #      just rebuilt is actually used — compose otherwise keeps the
  #      running container when only the underlying image changed.
  #
  # We no longer swallow compose's stdout: when the recreate silently
  # no-ops (the April 2026 VM 915 stale-bundle class of bug) the only
  # signal was in the text compose prints about which containers it
  # left alone. verify_server_image below is the authoritative check,
  # but visible output helps when it dies.
  msg "applying compose changes"
  compose up -d
  msg "recreating server with new image"
  compose up -d --force-recreate agenthub-server

  verify_server_image
  probe_front_door

  # Install the new CLI last — everything above ran under the
  # previously-installed CLI against the freshly-pulled repo. The next
  # `agenthub` invocation will pick up the new script.
  install_new_cli

  ok "updated to $(git rev-parse --short HEAD)"
}

cmd_logs() {
  local svc="${1:-agenthub-server}"
  compose logs -f --tail=100 "$svc"
}

cmd_restart() {
  if [[ $# -eq 0 ]]; then
    msg "restarting all services"
    compose restart
  else
    msg "restarting $*"
    compose restart "$@"
  fi
}

usage() {
  cat <<'EOF'
Usage: agenthub <command> [args]

Commands:
  update [--check]       Pull latest, rebuild, recreate. --check is a dry-run.
  status                 Git + compose service status.
  logs [service]         Tail compose logs (default: agenthub-server).
  restart [service...]   Restart services (default: all).
  version                Current git SHA + date.

Config: /etc/agenthub/config (set AGENTHUB_DIR=/path/to/agenthubv2)
Override via AGENTHUB_CONFIG=/other/path/config
EOF
}

case "${1:-}" in
  update)  shift; cmd_update "$@" ;;
  status)  shift; cmd_status ;;
  logs)    shift; cmd_logs "$@" ;;
  restart) shift; cmd_restart "$@" ;;
  version) shift; cmd_version ;;
  -h|--help|help|"") usage ;;
  *)       die "unknown command: $1 (try: agenthub --help)" ;;
esac
