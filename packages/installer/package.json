    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "22.15.32",
    "@types/react": "18.3.12",
    "tsx": "4.19.4",
    "typescript": "5.8.3",
    "vitest": "2.1.8"
  }
