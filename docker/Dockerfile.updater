# syntax=docker/dockerfile:1.7
#
# AgentHub updater image.
#
# Ephemeral one-shot container invoked by the server when a user clicks
# "Update" in the Settings UI. Runs the same `agenthub update` CLI the
# operator can invoke from the host shell — identical code path, zero
# drift.
#
# Mounted at run time:
#   /repo                         — the install's git clone (rw)
#   /var/run/docker.sock          — host docker socket (for build + recreate)
#
# Env:
#   AGENTHUB_DIR=/repo            — tells the CLI where to operate
#
# Build (from repo root):
#   docker build -f docker/Dockerfile.updater -t agenthubv2-updater:local .
FROM alpine:3.20

# Baked in by the build scripts so scripts/agenthub can detect image
# drift via the label instead of mtime/committer-date heuristics.
ARG GIT_SHA=unknown
LABEL org.agenthub.git-sha=$GIT_SHA

RUN apk add --no-cache \
      bash \
      git \
      docker-cli \
      docker-cli-compose \
      curl \
      jq \
      coreutils \
    && rm -rf /var/cache/apk/*

# The CLI script is read at run time from the /repo bind mount, not baked
# into the image. Baking it used to cause a self-reinforcing staleness
# bug: the image was only rebuilt at install time, so every button-driven
# update ran the original install-day CLI forever — even after new CLIs
# landed in main. Bind-mounting guarantees the updater always runs the
# current tree's CLI.
#
# Contract for the server: it MUST mount $AGENTHUB_REPO_DIR:/repo:rw
# when it spawns this container (admin/update route).

# /repo is a host bind mount owned by the install user (uid 1000). The
# updater runs as root. Since git 2.35 that combination triggers
# "detected dubious ownership" and every git call fails. Same fix we
# applied to Dockerfile.server in the initial round.
RUN git config --global --add safe.directory /repo

# Default command runs the CLI's `update` subcommand, read directly from
# the bind mount. The server overrides with --check or other subcommands
# as needed.
ENTRYPOINT ["/repo/scripts/agenthub"]
CMD ["update"]
